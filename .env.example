# cp .env.example .env

FUNASR_VERSION=1.0.0
FUNASR_DEVICE=cuda

# HTTP API 模型（funasr-server 默认就是 sensevoice，通常不需要改）
# 如需修改，在 docker-compose 的 funasr-api command 里加 --model 参数

# WebSocket 模型
WS_ASR_MODEL=iic/SenseVoiceSmall
WS_ASR_ONLINE_MODEL=iic/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-online
WS_PUNC_MODEL=iic/punc_ct-transformer_zh-cn-common-vocab272727-pytorch

WS_PORT=10095

# API 鉴权
FUNASR_API_KEY=funasr-internal    # 内网使用的 API key，客户端请求时带 Authorization: Bearer funasr-internal

# Nginx
NGINX_HTTP_PORT=80

# 日志
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30
